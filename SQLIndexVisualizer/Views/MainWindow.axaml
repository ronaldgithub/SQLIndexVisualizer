<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SQLIndexVisualizer.ViewModels"
        xmlns:models="using:SQLIndexVisualizer.Models"
        xmlns:sp="using:ScottPlot.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="SQLIndexVisualizer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="SQL Index Visualizer"
        MinWidth="900" MinHeight="600"
        Width="1280" Height="800"
        Background="#1E1E1E">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- DataTemplates for the TreeView hierarchy -->
    <Window.DataTemplates>
        <TreeDataTemplate DataType="{x:Type models:TableGroup}" ItemsSource="{Binding Indexes}">
            <TextBlock Text="{Binding DisplayName}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="#4EC9B0"
                       Padding="2,3"/>
        </TreeDataTemplate>
        <DataTemplate DataType="{x:Type models:IndexItem}">
            <TextBlock Text="{Binding DisplayName}"
                       FontSize="12"
                       Foreground="#DCDCDC"
                       Padding="2,2"/>
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg"      Color="#252526"/>
        <SolidColorBrush x:Key="SectionBg"    Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#3C3C3C"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#DCDCDC"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#0E7ACC"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4EC9B0"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background"   Value="#3C3C3C"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="#555"/>
            <Setter Property="CaretBrush"   Value="White"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background"   Value="#3C3C3C"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="#555"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"   Value="#2D2D30"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background"   Value="#3C3C3C"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="#555"/>
            <Setter Property="Padding"      Value="10,5"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>
        <Style Selector="Button.accent">
            <Setter Property="Background"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background"   Value="#267F61"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>
        <Style Selector="Button.warning">
            <Setter Property="Background"   Value="#6F4300"/>
            <Setter Property="Foreground"   Value="#CE9178"/>
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"   Value="Transparent"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background"   Value="#3C3C3C"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="#555"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="14,8"/>
            <Setter Property="Foreground"   Value="#888"/>
            <Setter Property="Background"   Value="Transparent"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground"   Value="White"/>
        </Style>
    </Window.Styles>

    <!-- ═══════════════════ Main layout ═══════════════════ -->
    <DockPanel Background="#1E1E1E">

        <!-- ── Status bar (bottom) ── -->
        <Border DockPanel.Dock="Bottom"
                Background="#007ACC"
                Padding="10,3">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{Binding StatusServer, StringFormat='⬡ {0}'}"
                               Foreground="White" FontSize="12" VerticalAlignment="Center"
                               IsVisible="{Binding IsConnected}"/>
                    <TextBlock Text="{Binding StatusDb, StringFormat='◈ {0}'}"
                               Foreground="White" FontSize="12" VerticalAlignment="Center"
                               IsVisible="{Binding StatusDb, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding TotalPagesSampled, StringFormat='▦ {0:N0} records'}"
                               Foreground="White" FontSize="12" VerticalAlignment="Center"
                               IsVisible="{Binding HasData}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main content ── -->
        <Grid ColumnDefinitions="280,4,*">

            <!-- ══════════ LEFT PANEL ══════════ -->
            <DockPanel Grid.Column="0" Background="{StaticResource PanelBg}" LastChildFill="True">

                <!-- Connection section -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SectionBg}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,10,10,12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="SQL SERVER CONNECTION"
                                   FontSize="10" Foreground="#888"
                                   FontWeight="Bold" LetterSpacing="1"/>
                        <Rectangle Height="1" Fill="#3C3C3C" Margin="0,2"/>

                        <TextBlock Text="Server" FontSize="11" Foreground="#888"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ServerName}"
                                     FontSize="13"
                                     PlaceholderText="localhost"
                                     Margin="0,0,4,0"/>
                            <Button Grid.Column="1"
                                    Content="{Binding ConnectButtonText}"
                                    Command="{Binding ConnectCommand}"
                                    Classes="accent"
                                    IsEnabled="{Binding IsConnecting, Converter={x:Static BoolConverters.Not}}"
                                    FontSize="12"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#3C3C3C" Margin="0,2"/>

                        <TextBlock Text="Database" FontSize="11" Foreground="#888"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Databases}"
                                      SelectedItem="{Binding SelectedDatabase}"
                                      PlaceholderText="Select database..."
                                      FontSize="13"
                                      Margin="0,0,4,0"
                                      HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1"
                                    Content="Load"
                                    Command="{Binding LoadTablesCommand}"
                                    IsEnabled="{Binding IsConnected}"
                                    FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Table/Index header -->
                <Border DockPanel.Dock="Top" Padding="10,6,10,2">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="TABLES &amp; INDEXES"
                                   FontSize="10" Foreground="#888"
                                   FontWeight="Bold" LetterSpacing="1"
                                   VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1"
                                     IsIndeterminate="True"
                                     IsVisible="{Binding IsLoadingTables}"
                                     Width="60" Height="3"/>
                    </Grid>
                </Border>

                <!-- TreeView of tables + indexes -->
                <TreeView x:Name="IndexTree"
                          ItemsSource="{Binding TableGroups}"
                          Background="Transparent"
                          Padding="4,0,4,4"
                          SelectionChanged="OnTreeViewSelectionChanged"/>
            </DockPanel>

            <!-- ── Splitter ── -->
            <GridSplitter Grid.Column="1"
                          Background="{StaticResource BorderBrush}"
                          ResizeDirection="Columns"/>

            <!-- ══════════ RIGHT PANEL ══════════ -->
            <DockPanel Grid.Column="2" Background="#1E1E1E" LastChildFill="True">

                <!-- ── Top info bar ── -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SectionBg}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding InfoTitle}"
                                       FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock Text="{Binding ServerName, StringFormat='Server: {0}'}"
                                           FontSize="11" Foreground="#888"
                                           IsVisible="{Binding IsConnected}"/>
                                <TextBlock Text="{Binding SelectedDatabase, StringFormat='DB: {0}'}"
                                           FontSize="11" Foreground="#888"
                                           IsVisible="{Binding SelectedDatabase, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Text="{Binding CurrentIndexInfo.SampleDT, StringFormat='Sampled: {0}'}"
                                           FontSize="11" Foreground="#888"
                                           IsVisible="{Binding CurrentIndexInfo.SampleDT, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center">
                            <Button Content="⟳  Analyse"
                                    Command="{Binding ReAnalyzeCommand}"
                                    Classes="accent" FontSize="12"/>
                            <Button Content="✕ Cancel"
                                    Command="{Binding CancelOperationCommand}"
                                    IsVisible="{Binding IsAnalyzing}"
                                    FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Stats bar ── -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SectionBg}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,8"
                        IsVisible="{Binding HasData}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <StackPanel Spacing="1">
                            <TextBlock Text="Pages Sampled" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding TotalPagesSampled, StringFormat='{}{0:N0}'}"
                                       FontSize="20" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Row Count" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding TableRowCount, StringFormat='{}{0:N0}'}"
                                       FontSize="20" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Index Size" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding IndexSizeDisplay}"
                                       FontSize="20" FontWeight="Bold" Foreground="#9CDCFE"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Avg Page Density" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding AvgPageDensity, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold" Foreground="#4EC9B0"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Min Density" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding MinPageDensity, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold" Foreground="#CE9178"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Max Density" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding MaxPageDensity, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold" Foreground="#9CDCFE"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Fill Factor" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding SelectedIndexItem.FillFactor, StringFormat='{}{0}%', FallbackValue='0%'}"
                                       FontSize="20" FontWeight="Bold" Foreground="#DCDCAA"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Avg Free Space" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding AvgFragmentation, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold" Foreground="#F14C4C"/>
                        </StackPanel>
                        <StackPanel Spacing="1" IsVisible="{Binding HasIndexFragmentation}">
                            <TextBlock Text="Index Fragmentation" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding IndexFragmentation, StringFormat='{}{0:F1}%'}"
                                       FontSize="20" FontWeight="Bold" Foreground="#CE9178"/>
                        </StackPanel>
                        <StackPanel Spacing="1">
                            <TextBlock Text="Avg Page Read" FontSize="10" Foreground="#888"/>
                            <TextBlock Text="{Binding AvgPageRead, StringFormat='{}{0:N0} µs'}"
                                       FontSize="20" FontWeight="Bold" Foreground="#B8D7A3"/>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ── Tab area: Analysis | Maintenance ── -->
                <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                            Background="#1E1E1E"
                            Padding="0">

                    <!-- ── Tab 0: Analysis (chart) ── -->
                    <TabItem Header="Analysis">
                        <Grid>
                            <!-- ScottPlot chart – always in the visual tree so it initialises properly -->
                            <sp:AvaPlot x:Name="IndexChart"/>

                            <!-- Empty / Welcome state – opaque background covers the chart -->
                            <Border Background="#1E1E1E" IsVisible="{Binding ShowEmptyState}">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="12">
                                    <TextBlock Text="📊" FontSize="72" HorizontalAlignment="Center"/>
                                    <TextBlock Text="SQL Index Visualizer"
                                               FontSize="24" FontWeight="Bold"
                                               HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock Text="1.  Connect to a SQL Server"
                                               FontSize="14" HorizontalAlignment="Center" Foreground="#666"/>
                                    <TextBlock Text="2.  Select a database and click Load"
                                               FontSize="14" HorizontalAlignment="Center" Foreground="#666"/>
                                    <TextBlock Text="3.  Select an index and click Analyse"
                                               FontSize="14" HorizontalAlignment="Center" Foreground="#666"/>
                                </StackPanel>
                            </Border>

                            <!-- Analyzing state – opaque background covers the chart -->
                            <Border Background="#1E1E1E" IsVisible="{Binding IsAnalyzing}">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="20"
                                            MaxWidth="540">

                                    <TextBlock Text="Analyzing index pages…"
                                               FontSize="16" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="White"/>

                                    <TextBlock Text="{Binding ElapsedSeconds}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Foreground="#888"/>

                                    <!-- SQL code block -->
                                    <Border Background="#0D1117"
                                            BorderBrush="#30363D"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="16,12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Executing:"
                                                       FontSize="10"
                                                       Foreground="#6E7681"
                                                       FontWeight="Bold"
                                                       LetterSpacing="1"/>
                                            <TextBlock Text="{Binding CurrentSql}"
                                                       FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                                                       FontSize="13"
                                                       Foreground="#8BE9FD"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="This may take several minutes for large indexes."
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               Foreground="#555"/>
                                </StackPanel>
                            </Border>

                            <!-- Error state -->
                            <Border IsVisible="{Binding HasError}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Background="#3C1F1F"
                                    BorderBrush="#F14C4C"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="20,14"
                                    MaxWidth="620">
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="#F14C4C"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ── Tab 1: Maintenance ── -->
                    <TabItem Header="Maintenance">
                        <Grid RowDefinitions="*,180">

                            <!-- ── Inner sub-tabs: Ola | T-SQL ── -->
                            <TabControl Grid.Row="0"
                                        SelectedIndex="{Binding MaintenanceSubTabIndex}"
                                        Background="#1E1E1E"
                                        Padding="0">

                                <!-- Ola IndexOptimize -->
                                <TabItem Header="Ola">
                                    <DockPanel>
                                        <!-- Execute strip -->
                                        <Border DockPanel.Dock="Bottom"
                                                Background="#252526"
                                                BorderBrush="#3C3C3C"
                                                BorderThickness="0,1,0,0"
                                                Padding="16,10">
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <Button Content="▶  Execute"
                                                        Command="{Binding ExecuteIndexOptimizeCommand}"
                                                        Classes="accent"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Padding="18,7"/>
                                                <Button Content="✕ Cancel"
                                                        Command="{Binding CancelOperationCommand}"
                                                        IsVisible="{Binding IsAnalyzing}"
                                                        FontSize="12"/>
                                                <TextBlock Text="{Binding ElapsedSeconds}"
                                                           FontSize="11" Foreground="#888"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Editable IndexOptimize SQL -->
                                        <Border Background="#0D1117"
                                                BorderBrush="#30363D"
                                                BorderThickness="0">
                                            <TextBox Text="{Binding IndexOptimizeSql}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="NoWrap"
                                                     FontFamily="Cascadia Code,Consolas,Courier New"
                                                     FontSize="13"
                                                     Foreground="#8BE9FD"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     CaretBrush="White"
                                                     SelectionBrush="#264F78"
                                                     Padding="16,12"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                        </Border>
                                    </DockPanel>
                                </TabItem>

                                <!-- Free-form T-SQL -->
                                <TabItem Header="T-SQL">
                                    <DockPanel>
                                        <!-- Execute strip -->
                                        <Border DockPanel.Dock="Bottom"
                                                Background="#252526"
                                                BorderBrush="#3C3C3C"
                                                BorderThickness="0,1,0,0"
                                                Padding="16,10">
                                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <Button Content="▶  Execute"
                                                        Command="{Binding ExecuteTsqlCommand}"
                                                        Classes="accent"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Padding="18,7"/>
                                                <Button Content="✕ Cancel"
                                                        Command="{Binding CancelOperationCommand}"
                                                        IsVisible="{Binding IsAnalyzing}"
                                                        FontSize="12"/>
                                                <TextBlock Text="{Binding ElapsedSeconds}"
                                                           FontSize="11" Foreground="#888"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0,0,0"/>
                                                <TextBlock Text="{Binding SelectedDatabase, StringFormat='  db: {0}'}"
                                                           FontSize="11" Foreground="#4EC9B0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Editable free-form SQL -->
                                        <Border Background="#0D1117"
                                                BorderBrush="#30363D"
                                                BorderThickness="0">
                                            <TextBox x:Name="TsqlEditor"
                                                     Text="{Binding CustomSql}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="NoWrap"
                                                     FontFamily="Cascadia Code,Consolas,Courier New"
                                                     FontSize="13"
                                                     Foreground="#CE9178"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     CaretBrush="White"
                                                     SelectionBrush="#264F78"
                                                     Padding="16,12"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                        </Border>
                                    </DockPanel>
                                </TabItem>

                            </TabControl>

                            <!-- Shared output log -->
                            <ScrollViewer x:Name="LogScrollViewer"
                                          Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="#111111">
                                <ItemsControl ItemsSource="{Binding MaintenanceLog}"
                                              Padding="16,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                                       FontSize="11"
                                                       Foreground="#A8FF78"
                                                       Padding="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                        </Grid>
                    </TabItem>

                    <!-- ── Tab 2: Activity ── -->
                    <TabItem Header="Activity">
                        <Grid RowDefinitions="Auto,*,Auto">

                            <!-- Controls row -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource SectionBg}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="14,10">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Button Content="Set Baseline"
                                            Command="{Binding TakeBaselineCommand}"
                                            Classes="accent"/>
                                    <TextBox Text="{Binding MeasurementLabel}"
                                             PlaceholderText="Action label (optional)"
                                             Width="180" FontSize="13"/>
                                    <Button Content="▶  Measure"
                                            Command="{Binding MeasureCommand}"
                                            Classes="success"/>
                                    <Button Content="Clear"
                                            Command="{Binding ClearMeasurementsCommand}"/>
                                    <Rectangle Width="1" Fill="#3C3C3C" Margin="4,0"/>
                                    <TextBlock Text="{Binding BaselineTime, StringFormat='Baseline: {0}'}"
                                               IsVisible="{Binding HasBaseline}"
                                               FontSize="12" Foreground="#9CDCFE"
                                               VerticalAlignment="Center"/>
                                    <!-- Legend (only when data exists) -->
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                IsVisible="{Binding HasMeasurements}"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0">
                                        <Rectangle Width="12" Height="12" Fill="#4472C4" VerticalAlignment="Center"/>
                                        <TextBlock Text="Page Splits" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                        <Rectangle Width="12" Height="12" Fill="#E05252" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Lock Waits" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Bar chart — AvaPlot always visible (ScottPlot Skia init gotcha) -->
                            <Grid Grid.Row="1">
                                <sp:AvaPlot x:Name="ActivityChart"/>
                                <!-- Opaque empty-state overlay -->
                                <Border Background="#1E1E1E"
                                        IsVisible="{Binding HasMeasurements, Converter={x:Static BoolConverters.Not}}">
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Spacing="10">
                                        <TextBlock Text="📈" FontSize="48" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Page Splits &amp; Lock Waits Monitor"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Foreground="#666"/>
                                        <TextBlock Text="1.  Select an index in the tree"
                                                   FontSize="13" HorizontalAlignment="Center" Foreground="#444"/>
                                        <TextBlock Text="2.  Click Set Baseline"
                                                   FontSize="13" HorizontalAlignment="Center" Foreground="#444"/>
                                        <TextBlock Text="3.  Run a T-SQL action in the Maintenance tab"
                                                   FontSize="13" HorizontalAlignment="Center" Foreground="#444"/>
                                        <TextBlock Text="4.  Click Measure to capture the delta"
                                                   FontSize="13" HorizontalAlignment="Center" Foreground="#444"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Measurements history table -->
                            <Border Grid.Row="2"
                                    Background="#111111"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    IsVisible="{Binding HasMeasurements}"
                                    MaxHeight="150">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <!-- Header -->
                                        <Grid ColumnDefinitions="*,90,90,100,70"
                                              Margin="16,6,16,4">
                                            <TextBlock Grid.Column="0" Text="Action"
                                                       FontSize="10" Foreground="#666" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="Page Splits"
                                                       FontSize="10" Foreground="#666" FontWeight="Bold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="2" Text="Lock Waits"
                                                       FontSize="10" Foreground="#666" FontWeight="Bold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="3" Text="Wait (ms)"
                                                       FontSize="10" Foreground="#666" FontWeight="Bold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="4" Text="Time"
                                                       FontSize="10" Foreground="#666" FontWeight="Bold"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Measurements}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:SplitLockMeasurement}">
                                                    <Grid ColumnDefinitions="*,90,90,100,70"
                                                          Margin="16,3,16,3">
                                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                   FontSize="12" Foreground="#DCDCDC"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding PageSplits, StringFormat='{}{0:N0}'}"
                                                                   FontSize="12" Foreground="#4472C4"
                                                                   HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding LockWaits, StringFormat='{}{0:N0}'}"
                                                                   FontSize="12" Foreground="#E05252"
                                                                   HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding WaitDisplay}"
                                                                   FontSize="12" Foreground="#888"
                                                                   HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding TimeDisplay}"
                                                                   FontSize="12" Foreground="#666"
                                                                   HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                        </Grid>
                    </TabItem>

                </TabControl>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
